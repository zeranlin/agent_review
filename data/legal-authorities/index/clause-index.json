    },
    {
      "clause_id": "LEGAL-001-ART-013",
      "reference_id": "LEGAL-001",
      "doc_title": "政府采购需求管理办法",
      "doc_no": "财库〔2021〕22号",
      "authority_level": "部门规范性文件",
      "validity_status": "有效",
      "chapter_label": "第三章",
      "article_label": "第十三条",
      "clause_text": "采购实施计划主要包括以下内容：（一）合同订立安排，包括采购项目预（概）算、最高限价，开展采购活动的时间安排，采购组织形式和委托代理安排，采购包划分与合同分包，供应商资格条件，采购方式、竞争范围和评审规则等。（二）合同管理安排，包括合同类型、定价方式、合同文本的主要条款、履约验收方案、风险管控措施等。",
